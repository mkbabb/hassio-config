{
  "title": "Presence",
  "path": "presence",
  "icon": "mdi:motion-sensor",
  "theme": "ios-dark-mode-blue-red",
  "type": "masonry",
  "badges": [],
  "cards": [
    {
      "type": "vertical-stack",
      "cards": [
        {
          "type": "custom:mushroom-template-card",
          "primary": "Presence Summary",
          "secondary": "{% set ns = namespace(occupied=0, pending=0) %}{% for area in ['bonus_room','downstairs_bathroom','garage','guest_bathroom','guest_bedroom','laundry_room','master_bathroom','plant_room','upstairs_hall'] %}{% set s = states('sensor.presence_' ~ area ~ '_state') %}{% if s == 'on' %}{% set ns.occupied = ns.occupied + 1 %}{% elif s == 'pending_off' %}{% set ns.pending = ns.pending + 1 %}{% endif %}{% endfor %}{{ ns.occupied }} occupied | {{ ns.pending }} cooling down | {{ 9 - ns.occupied - ns.pending }} vacant",
          "icon": "mdi:home-account",
          "icon_color": "{% if is_state('input_select.home_status', 'home') %}green{% else %}grey{% endif %}",
          "layout": "horizontal",
          "fill_container": true
        },
        {
          "type": "entities",
          "entities": [
            {
              "entity": "input_boolean.presence_pause",
              "name": "Pause All Presence Detection"
            },
            {
              "entity": "input_select.home_status",
              "name": "Home Status"
            }
          ],
          "state_color": true
        }
      ]
    },
    {
      "type": "vertical-stack",
      "cards": [
        {
          "type": "custom:mushroom-template-card",
