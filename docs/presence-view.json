          "icon": "{% set s = states('sensor.presence_bonus_room_state') %}{% if s == 'on' %}mdi:motion-sensor{% elif s == 'pending_off' %}mdi:timer-sand{% else %}mdi:motion-sensor-off{% endif %}",
          "icon_color": "{% set s = states('sensor.presence_bonus_room_state') %}{% if s == 'on' %}green{% elif s == 'pending_off' %}amber{% else %}grey{% endif %}",
          "badge_icon": "{% if states('sensor.presence_bonus_room_state') == 'disabled' %}mdi:pause-circle{% endif %}",
          "layout": "horizontal",
          "tap_action": {
            "action": "more-info",
            "entity": "sensor.presence_bonus_room_state"
          }
        },
        {
          "type": "entities",
          "title": "Controlled Entities",
          "show_header_toggle": false,
          "state_color": true,
          "entities": [
            {
              "entity": "light.bonus_room_ceiling_light",
              "name": "Ceiling Light"
            },
            {
              "entity": "light.bonus_room_light",
              "name": "Bonus Room Light"
            },
            {
              "entity": "light.fishing_lamp",
              "name": "Fishing Lamp"
            },
            {
              "entity": "light.hey_lamp_2_2",
              "name": "Hey Lamp"
            }
          ]
        },
        {
          "type": "markdown",
          "content": "**Base Cooldown:** 600s (10min) | **Override Policy:** respect\n\n**Cooldown Total:** {{ state_attr('sensor.presence_bonus_room_state', 'cooldown_total_min') | default('N/A') }}min{% if state_attr('sensor.presence_bonus_room_state', 'cooldown_remaining_min') | default(0) | float(0) > 0 %} | **Remaining:** {{ state_attr('sensor.presence_bonus_room_state', 'cooldown_remaining_min') | default(0) | round(1) }}min{% endif %}"
        },
        {
          "type": "conditional",
          "conditions": [
            {
              "condition": "state",
              "entity": "sensor.presence_bonus_room_state",
              "state_not": "disabled"
            }
