          "card": {
            "type": "custom:mushroom-chips-card",
            "chips": [
              {
                "type": "action",
                "icon": "mdi:pause-circle",
                "tap_action": {
                  "action": "call-service",
                  "service": "rest_command.presence_configure",
                  "data": {
                    "payload": "{\"topic\": \"bonus_room\", \"enabled\": false}"
                  },
                  "confirmation": {
                    "text": "Disable presence detection for Bonus Room?"
                  }
                },
                "hold_action": {
                  "action": "none"
                }
              }
            ],
            "alignment": "center"
          }
        },
