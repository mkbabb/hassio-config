{
    "name": "node-red-scripts",
    "version": "1.0.1",
    "description": "Collection of scripts for usage within Home Assistant's Node Red instance",
    "type": "module",
    "scripts": {
        "build": "tsx build -i src -o dist -r",
        "watch": "tsx build -i src -o dist -r -w",
        "build:deploy": "tsx build -i src -o dist -r --deploy",
        "deploy": "tsx build/deploy/deploy.ts",
        "deploy:all": "tsx build/deploy/deploy.ts --all",
        "deploy:dry-run": "tsx build/deploy/deploy.ts --dry-run",
        "deploy:rename": "tsx build/deploy/deploy.ts --rename-only",
        "map": "tsx build --map",
        "map:ai": "tsx build --map --ai",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@rollup/plugin-commonjs": "^28.0.8",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "axios": "^1.12.2",
        "chalk": "^5.6.2",
        "chokidar": "^4.0.3",
        "dotenv": "^17.2.3",
        "esbuild": "^0.25.11",
        "node-fetch": "^3.3.2",
        "openai": "^6.6.0",
        "prettier": "^3.6.2",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vite": "^7.1.11",
        "vite-plugin-commonjs": "^0.10.4",
        "yargs": "^18.0.0"
    },
    "author": "Mike Babb <mike@babb.dev>",
    "license": "ISC",
    "devDependencies": {
        "@types/node": "^24.9.1",
        "@types/yargs": "^17.0.33"
    }
}
