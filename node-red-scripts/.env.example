# Node-RED Deployment Configuration
NODE_RED_URL=http://homeassistant.local:1880
NODE_RED_FLOWS_PATH=/path/to/addon_configs/nodered/flows.json

# Home Assistant credentials for Node-RED API authentication
HA_USERNAME=your-username
HA_PASSWORD=your-password

# Home Assistant token for Supervisor API (addon restart fallback)
HA_TOKEN=your-home-assistant-long-lived-access-token-here

# OpenAI API key for AI reconciliation (optional)
OPENAI_API_KEY=your-openai-api-key-here

# InfluxDB credentials (used by test-runner)
INFLUXDB_USERNAME=homeassistant
INFLUXDB_PASSWORD=your-influxdb-password-here

# Deployment Options
DEPLOY_BACKUP=true
DEPLOY_DRY_RUN=false